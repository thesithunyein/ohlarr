# ── Ohlarr Web App Environment Variables ──────────────────────────────
# Copy this to .env.local for local dev, or set on Vercel dashboard.

# Program ID (deployed on Solana devnet)
NEXT_PUBLIC_PROGRAM_ID=CmHUW6WAUcobsYCHpK2cSgjcYU5KqbW8MDXunK5SzdLA

# Solana RPC endpoints
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PER_RPC_URL=https://devnet-tee.magicblock.app

# Demo keypair for /api/demo route (base64-encoded 64-byte secret key)
# Generate: solana-keygen new --outfile demo.json
# Encode:   cat demo.json | python3 -c "import json,base64,sys; print(base64.b64encode(bytes(json.load(sys.stdin))).decode())"
# Fund:     solana airdrop 2 <pubkey> --url devnet
DEMO_KEYPAIR=
